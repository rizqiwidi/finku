// Prisma schema for Supabase PostgreSQL
// Use this file for Vercel/Supabase deployment
// Rename to schema.prisma when deploying to Vercel

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// User model for authentication
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  password     String
  name         String?
  email        String?
  role         String   @default("user") // 'admin' or 'user'
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  categories   Category[]
  budgets      Budget[]
  transactions Transaction[]
  settings     UserSettings?
}

// User settings for savings and budget preferences
model UserSettings {
  id                    String   @id @default(cuid())
  monthlyIncome         Float    @default(0) // Monthly income for budget allocation
  savingsPercentage     Float    @default(20) // Percentage of income to save
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Category model for income/expense/savings categories
model Category {
  id              String   @id @default(cuid())
  name            String
  icon            String
  color           String
  type            String   // 'income', 'expense', or 'savings'
  budget          Float?   // Default monthly budget for expense categories
  allocationPercentage Float? @default(0) // Percentage allocation from income
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@index([userId, type])
}

// Transaction model for income, expense, and savings records
model Transaction {
  id          String   @id @default(cuid())
  amount      Float
  description String
  type        String   // 'income', 'expense', or 'savings'
  date        DateTime
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([userId, date])
  @@index([userId, type, date])
}

// Budget model for tracking monthly budgets per category
model Budget {
  id       String   @id @default(cuid())
  amount   Float    // Budget amount calculated from allocation
  period   String   // 'monthly' or 'yearly'
  month    Int      // 1-12
  year     Int      // e.g., 2024
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, month, year])
  @@index([userId, month, year])
}
