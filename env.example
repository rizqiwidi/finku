# ============================================
# Finku - Environment Variables
# ============================================

# Database Configuration
# ----------------------
# Untuk development lokal menggunakan SQLite
DATABASE_URL="file:./db/custom.db"

# Untuk production menggunakan PostgreSQL (Supabase/Neon/Railway)
# DATABASE_URL="postgresql://postgres:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[project-ref].supabase.co:5432/postgres"

# JWT Secret
# ----------
# Secret key untuk signing JWT tokens
# Ganti dengan string acak 32+ karakter untuk production
# Generate dengan: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"

# ============================================
# Cara Generate JWT Secret untuk Production:
# ============================================
# Di terminal, jalankan salah satu:
#
# openssl rand -base64 32
#
# atau
#
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# atau gunakan online generator: https://generate-secret.vercel.app/32
