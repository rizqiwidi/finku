# Shared Postgres connection
DATABASE_URL="postgresql://postgres:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[project-ref].supabase.co:5432/postgres"

# JWT signing secret
JWT_SECRET="REPLACE_ME_WITH_AT_LEAST_32_RANDOM_CHARACTERS"

# One-time admin bootstrap
ADMIN_BOOTSTRAP_USERNAME="admin"
ADMIN_BOOTSTRAP_PASSWORD="REPLACE_ME_WITH_A_STRONG_PASSWORD"
ADMIN_BOOTSTRAP_NAME="Administrator"
ADMIN_BOOTSTRAP_EMAIL="admin@example.com"

# Optional feature flag for /api/users/active
ENABLE_ACTIVE_USERS_METRIC="false"
